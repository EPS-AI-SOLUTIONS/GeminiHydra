{
  "framework": "vite",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "regions": ["cdg1", "fra1", "iad1"],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':!docs' ':!*.md' ':!scripts' ':!.claude'",
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
