# Skopiuj: cp .act.secrets.example .act.secrets
# Wypełnij prawdziwymi wartościami NIE commituj .act.secrets!

# GitHub Personal Access Token dla sparse-clone crates/ z JaskierWorkspace
# Potrzebny do: "Set up shared workspace crates" krok w backend job
# Stwórz: https://github.com/settings/tokens (repo scope wystarczy)
GH_PAT=ghp_your_token_here

# Opcjonalne: jeśli masz lokalną bazę PostgreSQL dla sqlx
# DATABASE_URL=postgresql://gemini:gemini_local@localhost:5432/geminihydra
